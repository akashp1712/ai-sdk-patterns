# ============================================
# AI SDK Patterns — Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local

# ------ Site Configuration ------

# Public URL of the deployed site (used for registry endpoint, CLI install
# commands, sitemap, OpenGraph, etc.)
NEXT_PUBLIC_SITE_URL=https://ai-sdk-patterns.dev

# ------ AI Routes ------

# Enable AI-powered API routes (/api/chat, /api/generate).
# Default: disabled — the app runs as a fully static site with zero serverless cost.
# Set to "true" only when you want live AI previews (requires at least one API key below).
# ENABLE_AI_ROUTES=true

# ------ AI Provider Keys ------
# Required only if ENABLE_AI_ROUTES=true. Add at least one.

ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=

# Default model used by the AI routes (format: provider:model-name)
# DEFAULT_MODEL=anthropic:claude-sonnet-4-5
